<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <title>View Parks</title>
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h1>Park Listing</h1>
        <p class="text-muted">Manage parks by editing or removing them.</p>
      </div>
      <a href="/addPark" class="btn btn-primary">Create Search Set</a>
    </div>

    <% if (filters && (filters.feat1 || filters.feat2 || filters.feat3 || filters.parkType)) { %>
      <div class="alert alert-secondary">
        <strong>Active set filters:</strong>
        <ul class="mb-0">
          <% if (filters.feat1) { %><li>Feature 1: <%= filters.feat1 %></li><% } %>
          <% if (filters.feat2) { %><li>Feature 2: <%= filters.feat2 %></li><% } %>
          <% if (filters.feat3) { %><li>Feature 3: <%= filters.feat3 %></li><% } %>
          <% if (filters.parkType) { %><li>Park type: <%= filters.parkType %></li><% } %>
        </ul>
      </div>
    <% } %>

    <div class="row mb-4">
      <div class="col-md-6 mb-3">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title">Set 1: Recommended Parks</h5>
            <p class="card-text">Top recommendations based on the current park list.</p>
            <ul>
              <% parks.slice(0, 3).forEach((park) => { %>
                <li><%= park.name %></li>
              <% }) %>
            </ul>
            <a class="btn btn-outline-primary btn-sm" href="#parks-list">View Set</a>
          </div>
        </div>
      </div>
      <div class="col-md-6 mb-3">
        <div class="card h-100 border-secondary">
          <div class="card-body">
            <h5 class="card-title">Set 2: Recommended Parks</h5>
            <p class="card-text">More parks you may want to explore.</p>
            <ul>
              <% parks.slice(3, 6).forEach((park) => { %>
                <li><%= park.name %></li>
              <% }) %>
            </ul>
            <a class="btn btn-outline-secondary btn-sm" href="#parks-list">View Set</a>
          </div>
        </div>
      </div>
    </div>

    <% if (parks.length > 0) { %>
      <div id="parks-list" class="row gy-4">
        <% parks.forEach((park, index) => { %>
          <div class="col-md-6">
            <div class="card h-100">
              <div class="card-body">
                <h5 class="card-title"><%= park.name %></h5>
                <p class="card-text"><strong>Description:</strong> <%= park.description %></p>
                <p class="card-text"><strong>Location:</strong> <%= park.location %></p>
                <p class="card-text"><strong>Contacts:</strong> <%= park.contacts || '—' %></p>
                <p class="card-text mb-1"><strong>Features:</strong></p>
                <ul>
                  <li><%= park.feat1 || '—' %></li>
                  <li><%= park.feat2 || '—' %></li>
                  <li><%= park.feat3 || '—' %></li>
                </ul>
                <p class="card-text"><strong>Park type:</strong> <%= park.parkType || '—' %></p>
                <a href="/editPark/<%= index %>" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                <a href="/removePark/<%= index %>" class="btn btn-sm btn-outline-danger">Remove</a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="alert alert-info">No parks match this set. Adjust your search set or add a new park in the data.</div>
    <% } %>
  </div>
</body>
</html>
