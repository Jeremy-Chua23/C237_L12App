<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <title>Remove Park</title>
</head>
<body>
  <%- include('partials/navbar') %>
  <div class="container mt-4">
    <h1>Remove Park</h1>
    <p class="text-muted">Confirm whether you want to permanently remove this park.</p>

    <div class="card mb-4">
      <div class="card-body">
        <h5 class="card-title"><%= park.name %></h5>
        <p class="card-text"><strong>Location:</strong> <%= park.location %></p>
        <p class="card-text"><strong>Description:</strong> <%= park.description %></p>
        <p class="card-text"><strong>Type:</strong> <%= park.parkType || '—' %></p>
        <p class="card-text"><strong>Features:</strong> <%= park.feat1 || '—' %>, <%= park.feat2 || '—' %>, <%= park.feat3 || '—' %></p>
      </div>
    </div>

    <form action="/removePark/<%= index %>" method="POST" onsubmit="return confirm('Are you sure you want to delete this park? This action cannot be undone.');">
      <button type="submit" class="btn btn-danger">Delete</button>
      <a class="btn btn-secondary" href="/viewParks">Back</a>
    </form>
  </div>
</body>
</html>
